{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "simai",
  "patterns": [
    { "include": "#comment" },
    { "include": "#end-mark" },
    { "include": "#hs-modifier" },
    { "include": "#bpm" },
    { "include": "#measure" },
    { "include": "#slide-with-star" },
    { "include": "#slide-complex" },
    { "include": "#duration" },
    { "include": "#touch-hold" },
    { "include": "#touch" },
    { "include": "#hold" },
    { "include": "#tap-double" },
    { "include": "#tap-single" },
    { "include": "#each-separator" },
    { "include": "#pseudo-each" }
  ],
  "repository": {
    "comment": {
      "comment": "Line comments starting with ||",
      "name": "comment.line.double-pipe.simai",
      "match": "\\|\\|.*$"
    },
    "end-mark": {
      "comment": "End of chart marker E (standalone)",
      "name": "keyword.control.end.simai",
      "match": "^E$"
    },
    "hs-modifier": {
      "comment": "Hi-Speed modifier like <HS*2>, <HS*-1>, <HS*0.7>",
      "name": "entity.name.tag.hs.simai",
      "match": "<HS\\*-?[0-9]+\\.?[0-9]*>"
    },
    "bpm": {
      "comment": "BPM change like (120), (253.25)",
      "name": "meta.bpm.simai",
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.bpm.begin.simai" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.bpm.end.simai" }
      },
      "patterns": [
        {
          "name": "constant.numeric.bpm-value.simai",
          "match": "-?[0-9]+\\.?[0-9]*"
        }
      ]
    },
    "measure": {
      "comment": "Measure division like {4}, {8}, {-1}, {#0.035}",
      "name": "meta.measure.simai",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.measure.begin.simai" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.measure.end.simai" }
      },
      "patterns": [
        {
          "name": "support.function.measure-value.simai",
          "match": "#?-?[0-9]+\\.?[0-9]*"
        }
      ]
    },
    "duration": {
      "comment": "Duration like [4:1], [0##0.01], [32:1], [1.2##0.7]",
      "name": "meta.duration.simai",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.duration.begin.simai" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.duration.end.simai" }
      },
      "patterns": [
        {
          "name": "constant.numeric.duration-value.simai",
          "match": "[0-9]+\\.?[0-9]*"
        },
        {
          "name": "keyword.operator.duration-separator.simai",
          "match": ":|##"
        }
      ]
    },
    "slide-with-star": {
      "comment": "Star slide connector like *>6p1, *V53, *<2p5, *-3[0##0.01]",
      "name": "entity.name.function.slide-star.simai",
      "match": "\\*([<>^\\-qpwszvV][qp]?[1-8*]+)+(\\[[^\\]]*\\])?[bx!m]*"
    },
    "slide-complex": {
      "comment": "Complex slide patterns: 2?>4q2>4q2, 1-4[4:1], 1qq7[0##0.02]b, 7<5[0##0.01]b",
      "name": "entity.name.function.slide.simai",
      "match": "[1-8*][bx!m]*\\??([<>^\\-qpwszvV][qp]?[1-8*]+)+(\\[[^\\]]*\\])?[bx!m]*"
    },
    "touch-hold": {
      "comment": "Touch hold notes like B2bh[4:2], Cbh[4:2], E4bh, A5bh[1:3]",
      "name": "entity.name.type.touch-hold.simai",
      "match": "[ABCDE][1-8]?[bfxm]*h(\\[[^\\]]*\\])?[bfxm]*"
    },
    "touch": {
      "comment": "Touch notes like A1, B2, Cf, E4f, E6f, B7f",
      "name": "entity.name.type.touch.simai",
      "match": "[ABCDE][1-8]?[bfxhm]*(\\[[^\\]]*\\])?(?=[,/`\\s<]|$)"
    },
    "hold": {
      "comment": "Hold notes like 1h[4:4], 5bh[4:2], 4bh[4:1], 6h[8:2]",
      "name": "entity.name.class.hold.simai",
      "match": "[1-8][1-8]?[bx!m]*h(\\[[^\\]]*\\])?[bx!m]*"
    },
    "tap-double": {
      "comment": "Double tap (each shorthand) like 73, 36, 12, 17b",
      "name": "entity.name.variable.tap-double.simai",
      "match": "[1-8][1-8][bx!m]*(?=[,/`\\s\\[\\{\\(<h\\-\\>\\<\\^qpwszvV]|$)"
    },
    "tap-single": {
      "comment": "Single tap like 1, 2b, 3x, 4!, 5bx",
      "name": "entity.name.variable.tap.simai",
      "match": "[1-8][bx!m]*(?=[,/`\\s\\[\\{\\(<h\\-\\>\\<\\^qpwszvV]|$)"
    },
    "each-separator": {
      "comment": "Each note separator /",
      "name": "keyword.operator.each.simai",
      "match": "/"
    },
    "pseudo-each": {
      "comment": "Pseudo-each connector ` for connecting notes without triggering each",
      "name": "keyword.operator.pseudo-each.simai",
      "match": "`"
    }
  },
  "scopeName": "maidata.simai"
}
